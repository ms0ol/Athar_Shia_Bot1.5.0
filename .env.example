# Athar Shia Bot - Environment Variables
# انسخ هذا الملف إلى .env وعدل القيم

BOT_TOKEN=YOUR_BOT_TOKEN_HERE
CHANNEL_ID=@your_channel
ADMIN_IDS=123456789,987654321

# Default Location (Baghdad)
TIMEZONE=Asia/Baghdad
CITY=بغداد
LATITUDE=33.3152
LONGITUDE=44.3661

# Features
ENABLE_SUBSCRIPTIONS=true
MAX_DAILY_CONTENT=3
