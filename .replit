modules = ["python-3.11"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[deployment]
deploymentTarget = "cloudrun"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python app.py"

[workflows.workflow.metadata]
outputType = "console"
